# Mentoria Hub — environment variables
#
# The AI College Counselor calls Claude through a server-side route
# (src/app/api/chat/route.ts). Without a key, the counselor automatically
# falls back to the built-in offline responses, so the app still works.

# Required to enable the real AI chatbot. Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Optional — defaults to claude-opus-4-8 (most capable).
# Use claude-haiku-4-5 for a faster / cheaper counselor.
# ANTHROPIC_MODEL=claude-opus-4-8
